# Free a port on macOS: kill whatever is listening on it
freeport() {
  local PORT="$1"

  if [ -z "$PORT" ]; then
    echo "Usage: freeport <port>"
    return 1
  fi

  local PIDS
  PIDS=$(lsof -ti tcp:"$PORT")

  if [ -z "$PIDS" ]; then
    echo "Port $PORT is already free"
    return 0
  fi

  echo "Killing process(es) on port $PORT: $PIDS"
  kill -9 $PIDS
}

# List used TCP ports in a table (macOS)
usedports() {
  printf "%-8s %-22s %-6s %s\n" "PORT" "COMMAND" "PID" "USER"
  printf "%-8s %-22s %-6s %s\n" "----" "----------------------" "------" "----"

  lsof -nP -iTCP -sTCP:LISTEN | awk 'NR>1 {
    split($9,a,":");
    port=a[length(a)];
    printf "%-8s %-22s %-6s %s\n", port, $1, $2, $3
  }' | sort -n | uniq
}
