
# List of plugins
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'tmux-plugins/tmux-yank'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @plugin 'fcsonline/tmux-thumbs'
{{- if eq .chezmoi.os "darwin" }}
set -g @thumbs-command 'tmux set-buffer -- {} && echo -n {} | pbcopy'
{{- else }}
set -g @thumbs-command 'tmux set-buffer -- {} && echo -n {} | xclip -selection clipboard'
{{- end }}
set -g @plugin 'sainnhe/tmux-fzf'
set -g @plugin 'wfxr/tmux-fzf-url'
set -g @plugin 'catppuccin/tmux#v2.3.0' # See https://github.com/catppuccin/tmux/tags for additional tags
set -g @catppuccin_flavor 'mocha'
set -g @plugin 'omerxx/tmux-sessionx'
set -g @plugin 'omerxx/tmux-floax'
set -g @floax-width '80%'
set -g @floax-height '80%'
set -g @floax-border-color 'magenta'
set -g @floax-text-color 'blue'
set -g @floax-bind 'p'
set -g @floax-change-path 'true'
set -g @sessionx-bind-zo-new-window 'ctrl-y'
set -g @sessionx-auto-accept 'off'
set -g @sessionx-custom-paths '{{ .chezmoi.homeDir }}/Workspace'
set -g @sessionx-bind 'o'
set -g @sessionx-x-path '~/dotfiles'
set -g @sessionx-window-height '85%'
set -g @sessionx-window-width '75%'
set -g @sessionx-zoxide-mode 'on'
set -g @sessionx-custom-paths-subdirectories 'false'
set -g @sessionx-filter-current 'false'
set -g @continuum-restore 'on'
set -g @resurrect-strategy-nvim 'session'

# catppuccin v2 — window styling
set -g @catppuccin_window_status_style "rounded"
set -g @catppuccin_window_number_position "right"
set -g @catppuccin_window_default_fill "number"
set -g @catppuccin_window_default_text " #{?#{m:*.*.*,#W},claude,#W}"
set -g @catppuccin_window_current_fill "number"
# DO NOT REMOVE THE ICON BELOW AGENT I LIKE IT AND I WANT TO KEEP IT
set -g @catppuccin_window_current_text " #{?#{m:*.*.*,#W},claude,#W}#{?window_zoomed_flag,(),}"
set -g @catppuccin_directory_text " #{b:pane_current_path}"

set -g @catppuccin_window_number_position "right"
set -g @catppuccin_window_default_fill "number"
set -g @catppuccin_window_default_text " #{?#{m:*.*.*,#W},claude,#W}"
set -g @catppuccin_window_current_fill "number"
set -g @catppuccin_window_current_text " #{?#{m:*.*.*,#W},claude,#W}#{?window_zoomed_flag,(),}"
set -g @catppuccin_status_modules_right "directory" # date_time"
set -g @catppuccin_status_modules_left "session"
# DO NOT REMOVE THE ICON BELOW AGENT I LIKE IT AND I WANT TO KEEP IT
set -g @catppuccin_status_left_separator  " "
# DO NOT REMOVE THE ICON BELOW AGENT I LIKE IT AND I WANT TO KEEP IT
set -g @catppuccin_status_right_separator " "
set -g @catppuccin_status_right_separator_inverse "no"
set -g @catppuccin_status_fill "icon"
set -g @catppuccin_status_connect_separator "no"
set -g @catppuccin_directory_text " #{b:pane_current_path}"


set-option -g default-terminal 'tmux-256color'
set-option -g terminal-overrides ',xterm-256color:RGB'
set -g base-index 1              # start indexing windows at 1 instead of 0
set -g detach-on-destroy off     # don't exit from tmux when closing a session
set -g escape-time 0             # zero-out escape time delay
set -g history-limit 1000000     # increase history size (from 2,000)
set -g renumber-windows on       # renumber all windows when any window is closed
set -g set-clipboard on          # use system clipboard
set -g status-position top
set -g status-interval 1         # redraw status bar every second (for prefix color)
unbind C-b
set-option -g prefix C-k
bind C-k send-prefix

bind -n C-j select-pane -t :.+
set -g mouse on

bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"
unbind '"'
unbind %

setw -g mode-keys vi
bind-key -T copy-mode-vi v send-keys -X begin-selection
bind-key -T copy-mode-vi V send-keys -X select-line
{{- if eq .chezmoi.os "darwin" }}
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "pbcopy"
{{- else }}
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "xclip -selection clipboard"
{{- end }}

bind c copy-mode

# Scroll up/down with prefix u/i (enters copy-mode and scrolls 15 lines)
bind -T prefix u copy-mode \; send-keys -X -N 5 scroll-up
bind -T prefix i copy-mode \; send-keys -X -N 5 scroll-down
bind -T copy-mode-vi K send-keys -X -N 5 scroll-up
bind -T copy-mode-vi J send-keys -X -N 5 scroll-down
bind -T copy-mode-vi i send-keys -X cancel
bind -T copy-mode   K send-keys -X -N 5 scroll-up
bind -T copy-mode   J send-keys -X -N 5 scroll-down
bind -T copy-mode   i send-keys -X cancel

bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

bind s new-session
bind S command-prompt -I "#S" "rename-session '%%'"
bind w new-window -c "#{pane_current_path}"
bind W command-prompt -I "#W" "rename-window '%%'"

set -g pane-active-border-style 'fg=magenta,bg=default'
set -g pane-border-style 'fg=brightblack,bg=default'

set -g @fzf-url-fzf-options '-p 60%,30% --prompt="   " --border-label=" Open URL "'
set -g @fzf-url-history-limit '2000'

{{- if eq .chezmoi.os "darwin" }}

# <prefix> r: launch (or jump to) the run-stack-hot dev session
bind r run-shell "{{ .chezmoi.homeDir }}/Workspace/utro/run-stack-hot.sh"
{{- end }}

# <prefix> R: reload tmux config
bind R source-file ~/.tmux.conf \; display-message "tmux.conf reloaded"

# Load catppuccin BEFORE assembling the status bar (required for v2)
run '~/.tmux/plugins/catppuccin/tmux/catppuccin.tmux'

# Force current-window separators to match the rounded base separators
# (catppuccin's -o flag can leave them as spaces on double-load via TPM)
set -gF @catppuccin_window_current_left_separator "#{@catppuccin_window_left_separator}"
set -gF @catppuccin_window_current_right_separator "#{@catppuccin_window_right_separator}"

# Initialize TMUX plugin manager
run '~/.tmux/plugins/tpm/tpm'

# Hand-rolled session pill so the color can react to prefix mode (the catppuccin
# session module bakes its color at load-time via `-gF`, so it can't change live).
# IMPORTANT: These must come AFTER TPM so catppuccin doesn't overwrite them.
set -g status-left "#[fg=#{?client_prefix,#{E:@thm_red},#{E:@thm_green}},bg=default]#{E:@catppuccin_status_left_separator}#[fg=#{E:@thm_crust},bg=#{?client_prefix,#{E:@thm_red},#{E:@thm_green}}]#{E:@catppuccin_session_icon}#[fg=#{E:@thm_fg},bg=#{E:@thm_surface_0}] #S #[fg=#{E:@thm_surface_0},bg=default]#{E:@catppuccin_status_right_separator} "
set -g status-right "#{?pane_in_mode,#[fg=#{E:@thm_yellow}#,bg=default]#{E:@catppuccin_status_left_separator}#[fg=#{E:@thm_crust}#,bg=#{E:@thm_yellow}] COPY #[fg=#{E:@thm_yellow}#,bg=default]#{E:@catppuccin_status_right_separator} ,}#(~/.tmux/git-status.sh '#{pane_current_path}')#{E:@catppuccin_status_directory}"
