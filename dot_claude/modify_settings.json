#!/bin/sh
# Chezmoi modify_ script for ~/.claude/settings.json.
#
# Claude Code owns this file and rewrites it at runtime (model selection, UI
# toggles, etc.), so we cannot manage it as a regular chezmoi file. Instead,
# this script reads the current target on stdin and emits the same JSON with
# our managed keys injected (or overwritten) — all other keys Claude has
# written are preserved.
#
# Managed keys:
#   - statusLine:  points at our chezmoi-managed renderer. Lives here and not
#                  in settings.local.json because, on this install, a
#                  statusLine block there is silently ignored (see CLAUDE.md).
#   - hooks.Stop:  appends our session-recap regenerator. Idempotent: any
#                  previous entry referencing the same script is filtered out
#                  before append, so repeated applies don't duplicate it.
#                  Other Stop-hook entries are preserved untouched.
#
# This script must be byte-stable for unchanged inputs — otherwise every
# `chezmoi apply` would show a diff.

set -eu

input="$(cat)"
if [ -z "$input" ]; then
  input='{}'
fi

RECAP_HOOK_CMD='$HOME/.claude/hooks/regen-session-recap.sh'

printf '%s' "$input" | jq --arg recap "$RECAP_HOOK_CMD" '
  (. * {
    statusLine: {
      type: "command",
      command: "~/.claude/statusline/statusline.sh"
    }
  })
  | .hooks = (.hooks // {})
  | .hooks.Stop = (
      ((.hooks.Stop // [])
       | map(select(
           (.hooks // [])
           | map(.command // "")
           | any(. == $recap)
           | not
         )))
      + [{hooks: [{type: "command", command: $recap}]}]
    )
'
