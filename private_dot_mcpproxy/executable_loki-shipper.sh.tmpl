#!/bin/bash
# Streams MCPProxy activity events into Loki in real-time
# Runs as a persistent process, reconnects on failure

LOKI_URL="http://127.0.0.1:3100/loki/api/v1/push"
MCPPROXY="/opt/homebrew/bin/mcpproxy"
DATA_DIR="{{ .chezmoi.homeDir }}/.mcpproxy"

while true; do
  $MCPPROXY activity watch -o json --data-dir "$DATA_DIR" 2>/dev/null | while IFS= read -r line; do
    [ -z "$line" ] && continue

    payload=$(python3 -c "
import sys, json, time
from datetime import datetime

raw = sys.argv[1]
try:
    rec = json.loads(raw)
except:
    sys.exit(0)

ts = rec.get('timestamp', '')
try:
    dt = datetime.fromisoformat(ts.replace('Z', '+00:00'))
    ts_ns = str(int(dt.timestamp() * 1e9))
except:
    ts_ns = str(int(time.time() * 1e9))

payload = {
    'streams': [{
        'stream': {
            'job': 'mcpproxy',
            'source': 'mcpproxy-activity',
            'server': rec.get('server_name', 'unknown'),
            'event_type': rec.get('type', 'unknown'),
            'event_status': rec.get('status', 'unknown')
        },
        'values': [[ts_ns, json.dumps(rec)]]
    }]
}
print(json.dumps(payload))
" "$line" 2>/dev/null)

    if [ -n "$payload" ]; then
      curl -s -X POST "$LOKI_URL" \
        -H "Content-Type: application/json" \
        -d "$payload" >/dev/null 2>&1
    fi
  done

  # Reconnect after 5 seconds if the watch stream dies
  sleep 5
done
